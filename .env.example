SYNAPSE_ENV=development
SYNAPSE_APP_NAME=Synapse
SYNAPSE_DATABASE_URL=postgresql+psycopg://synapse:synapse@postgres:5432/synapse
SYNAPSE_REDIS_URL=redis://redis:6379/0
SYNAPSE_MINIO_ENDPOINT=minio:9000
SYNAPSE_MINIO_ACCESS_KEY=minioadmin
SYNAPSE_MINIO_SECRET_KEY=minioadmin
SYNAPSE_MINIO_BUCKET=synapse-artifacts
SYNAPSE_LLM_PROVIDER=minimax
SYNAPSE_DEFAULT_LLM_MODEL=MiniMax-M2.5
SYNAPSE_DEFAULT_PARSER=docling
SYNAPSE_EMBEDDING_PROVIDER=openrouter
SYNAPSE_DEFAULT_EMBEDDING_MODEL=operator-configured
SYNAPSE_PARSER_OCR_ENABLED=0
SYNAPSE_COLPALI_ENABLED=0
SYNAPSE_DEPLOYMENT_TARGET=testing
SYNAPSE_PUBLIC_BASE_URL=https://synapse.example.com
SYNAPSE_REVERSE_PROXY=caddy
SYNAPSE_GROBID_URL=http://grobid:8070
SYNAPSE_INGEST_CONCURRENCY=1
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
