SYNAPSE_ENV=development
SYNAPSE_APP_NAME=Synapse
SYNAPSE_DATABASE_URL=postgresql+psycopg://synapse:synapse@localhost:5432/synapse
SYNAPSE_REDIS_URL=redis://localhost:6379/0
SYNAPSE_MINIO_ENDPOINT=localhost:9000
SYNAPSE_MINIO_ACCESS_KEY=minioadmin
SYNAPSE_MINIO_SECRET_KEY=minioadmin
SYNAPSE_MINIO_BUCKET=synapse-artifacts
SYNAPSE_LLM_PROVIDER=ollama
SYNAPSE_DEFAULT_PARSER=docling
SYNAPSE_DEFAULT_EMBEDDING_MODEL=specter2
SYNAPSE_DEPLOYMENT_TARGET=local
SYNAPSE_PUBLIC_BASE_URL=
SYNAPSE_REVERSE_PROXY=none
SYNAPSE_GROBID_URL=http://localhost:8070
SYNAPSE_INGEST_CONCURRENCY=1
