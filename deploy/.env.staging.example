COMPOSE_PROJECT_NAME=synapse-testing
SYNAPSE_INSTALL_EXTRAS=research
SYNAPSE_PIP_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cpu

SYNAPSE_APP_NAME=Synapse
SYNAPSE_ENV=staging
SYNAPSE_VERSION=0.1.0
SYNAPSE_DEPLOYMENT_TARGET=testing
SYNAPSE_PUBLIC_BASE_URL=
SYNAPSE_REVERSE_PROXY=caddy

SYNAPSE_DATA_DIR=data
SYNAPSE_CORPUS_DIR=test_corpus
SYNAPSE_EVAL_DIR=eval

POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
SYNAPSE_DATABASE_URL=postgresql+psycopg://synapse:synapse@postgres:5432/synapse

SYNAPSE_REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
SYNAPSE_MINIO_ENDPOINT=minio:9000
SYNAPSE_MINIO_ACCESS_KEY=minioadmin
SYNAPSE_MINIO_SECRET_KEY=minioadmin
SYNAPSE_MINIO_BUCKET=synapse-artifacts

SYNAPSE_GROBID_URL=http://grobid:8070
GROBID_IMAGE=grobid/grobid:0.8.2-crf

SYNAPSE_LLM_PROVIDER=openai
OPENAI_API_KEY=
SYNAPSE_DEFAULT_PARSER=docling
SYNAPSE_DEFAULT_EMBEDDING_MODEL=specter2

SYNAPSE_STAGING_HTTP_PORT=18080
SYNAPSE_APP_PORT=18000
SYNAPSE_MINIO_API_PORT=19000
SYNAPSE_MINIO_CONSOLE_PORT=19001
SYNAPSE_SMOKE_OUTPUT_DIR=data/ingest-smoke
